UPLOAD_ID=recorder-a
UPLOAD_KEY=replace-with-a-private-key
SYSTEM_NAME=example-system
SPOOL_DIR=/var/lib/call-recorder-uploader
RETRY_COUNT=5
TIMEOUT_SECONDS=30
