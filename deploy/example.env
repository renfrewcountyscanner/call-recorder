# Copy to a private .env file and set real values outside Git.
CALL_RECORDER_LISTEN_ADDRESS=0.0.0.0
CALL_RECORDER_LISTEN_PORT=8080
CALL_RECORDER_DATABASE_URL=postgresql://call_recorder:CHANGE_ME@postgres:5432/call_recorder
CALL_RECORDER_AUDIO_ROOT=/var/lib/call-recorder/audio
CALL_RECORDER_RETENTION_DAYS=60
CALL_RECORDER_DUPLICATE_START_TOLERANCE_MS=2000
CALL_RECORDER_DUPLICATE_DURATION_TOLERANCE_MS=300
POSTGRES_DB=call_recorder
POSTGRES_USER=call_recorder
POSTGRES_PASSWORD=CHANGE_ME
CALL_RECORDER_PORT=8080
CALL_RECORDER_BOOTSTRAP_SENDER_ID=example-sender
CALL_RECORDER_BOOTSTRAP_SENDER_KEY=CHANGE_ME
# Administration is disabled by default. Enable only behind private/authenticated access.
CALL_RECORDER_ADMIN_ENABLED=false
CALL_RECORDER_ADMIN_TOKEN=CHANGE_ME
